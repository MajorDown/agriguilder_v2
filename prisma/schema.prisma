generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EmailAuthCodeContext {
  INSCRIPTION
  MAJ_EMAIL
}

model EmailAuthCode {
  id           String               @id @default(uuid())
  email        String
  code_hash    String
  errors       Int                  @default(0)
  validated_at DateTime?
  context      EmailAuthCodeContext
  created_at   DateTime             @default(now())

  @@index([email])
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  society       String?
  firstname     String
  lastname      String
  phone         String
  password_hash String
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  revoked_at    DateTime?

  sessions    Session[]
  memberships Member[]
  adminships  Admin[]
  employments Employee[]
  dev         Dev?
}

model Session {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String    @unique
  ip_mask    String
  user_agent String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  expires_at DateTime
  ended_at   DateTime?
  revoked_at DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model Dev {
  id         String   @id @default(uuid())
  user_id    String   @unique
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Guild {
  id                     String   @id @default(uuid())
  name                   String   @unique
  latitude               Float?
  longitude              Float?
  city                   String
  department             String
  human_hour_point_value Float    @default(1)
  max_declaration_delay  Int      @default(7)
  max_validation_delay   Int      @default(0)
  max_contestation_delay Int      @default(7)
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  reinitializations Reinitialization[]
  members           Member[]
  admins            Admin[]
  employees         Employee[]
  rules             Rule[]
  tools             Tool[]
  adjustments       Adjustment[]
  interventions     Intervention[]
  contestations     Contestation[]
  requests          Request[]
}

model Member {
  id             String    @id @default(uuid())
  guild_id       String
  user_id        String
  points_balance Float     @default(0)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  revoked_at     DateTime?

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  adjustments             Adjustment[]
  interventions_as_worker Intervention[] @relation("WorkerInterventions")
  interventions_as_payer  Intervention[] @relation("PayerInterventions")
  contestations           Contestation[] @relation("MemberContestations")
  created_requests        Request[]      @relation("RequestRequester")
  volunteer_for_requests  Request[]      @relation("RequestVolunteers")

  @@unique([guild_id, user_id])
  @@unique([id, guild_id])
  @@index([guild_id])
  @@index([user_id])
}

model Admin {
  id         String    @id @default(uuid())
  guild_id   String
  user_id    String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  revoked_at DateTime?

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  adjustments            Adjustment[]
  reinitializations      Reinitialization[]
  written_rules          Rule[]
  written_tools          Tool[]
  resolved_contestations Contestation[]

  @@unique([guild_id, user_id])
  @@unique([id, guild_id])
  @@index([guild_id])
  @@index([user_id])
}

model Employee {
  id         String    @id @default(uuid())
  guild_id   String
  user_id    String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  revoked_at DateTime?

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([guild_id, user_id])
  @@unique([id, guild_id])
  @@index([guild_id])
  @@index([user_id])
}

model Reinitialization {
  id               String   @id @default(uuid())
  guild_id         String
  admin_id         String
  point_euro_value Float
  created_at       DateTime @default(now())

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)
  admin Admin @relation(fields: [admin_id, guild_id], references: [id, guild_id], onDelete: Cascade)

  @@index([guild_id])
  @@index([admin_id])
}

model Rule {
  id         String   @id @default(uuid())
  guild_id   String
  admin_id   String
  content    String
  created_at DateTime @default(now())

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)
  admin Admin @relation(fields: [admin_id, guild_id], references: [id, guild_id], onDelete: Restrict)

  @@index([guild_id])
  @@index([admin_id])
}

enum ToolUnit {
  HEURE
  HECTARE
}

model Tool {
  id         String    @id @default(uuid())
  guild_id   String
  admin_id   String
  name       String
  unit       ToolUnit  @default(HEURE)
  coef       Float
  version    Int       @default(1)
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  revoked_at DateTime?

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)
  admin Admin @relation(fields: [admin_id, guild_id], references: [id, guild_id], onDelete: Restrict)

  interventions Intervention[]

  @@unique([id, guild_id])
  @@index([guild_id])
  @@index([admin_id])
}

enum AdjustmentType {
  INITIALISATION
  CORRECTION
}

model Adjustment {
  id         String         @id @default(uuid())
  guild_id   String
  admin_id   String
  member_id  String
  type       AdjustmentType
  amount     Float
  reason     String?
  created_at DateTime       @default(now())

  guild  Guild  @relation(fields: [guild_id], references: [id], onDelete: Cascade)
  admin  Admin  @relation(fields: [admin_id, guild_id], references: [id, guild_id], onDelete: Restrict)
  member Member @relation(fields: [member_id, guild_id], references: [id, guild_id], onDelete: Restrict)

  @@index([guild_id])
  @@index([member_id])
}

enum InterventionStatus {
  DECLARE
  VALIDEE
  CONTESTEE
  ANNULEE
}

model Intervention {
  id          String             @id @default(uuid())
  guild_id    String
  worker_id   String
  payer_id    String
  day         DateTime           @db.Date
  duration    Float?
  surface     Float?
  description String?
  status      InterventionStatus
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt

  guild  Guild  @relation(fields: [guild_id], references: [id], onDelete: Cascade)
  worker Member @relation("WorkerInterventions", fields: [worker_id, guild_id], references: [id, guild_id], onDelete: Restrict)
  payer  Member @relation("PayerInterventions", fields: [payer_id, guild_id], references: [id, guild_id], onDelete: Restrict)

  used_tools    Tool[]
  contestations Contestation[]

  @@index([guild_id])
  @@index([worker_id])
  @@index([payer_id])
  @@index([guild_id, status])
  @@index([guild_id, day])
}

enum ContestationStatus {
  EN_ATTENTE
  ACCEPTEE
  REFUSEE
}

model Contestation {
  id                   String             @id @default(uuid())
  guild_id             String
  intervention_id      String
  contester_id         String
  reason               String
  resolved_by_admin_id String?
  status               ContestationStatus @default(EN_ATTENTE)
  created_at           DateTime           @default(now())
  resolved_at          DateTime?

  guild        Guild        @relation(fields: [guild_id], references: [id], onDelete: Cascade)
  intervention Intervention @relation(fields: [intervention_id], references: [id], onDelete: Cascade)
  contester    Member       @relation("MemberContestations", fields: [contester_id, guild_id], references: [id, guild_id], onDelete: Restrict)
  resolved_by  Admin?       @relation(fields: [resolved_by_admin_id, guild_id], references: [id, guild_id], onDelete: Restrict)

  @@index([guild_id])
  @@index([intervention_id])
  @@index([guild_id, status])
}

enum RequestStatus {
  OUVERT
  EXPIRE
  RESERVE
  ANNULE
}

model Request {
  id                String        @id @default(uuid())
  guild_id          String
  requester_id      String
  planned_day       DateTime?
  expected_duration Float?
  description       String
  status            RequestStatus @default(OUVERT)
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  guild     Guild  @relation(fields: [guild_id], references: [id], onDelete: Cascade)
  requester Member @relation("RequestRequester", fields: [requester_id, guild_id], references: [id, guild_id], onDelete: Restrict)

  volunteers Member[] @relation("RequestVolunteers")

  @@index([guild_id])
  @@index([guild_id, status])
  @@index([guild_id, planned_day])
}
